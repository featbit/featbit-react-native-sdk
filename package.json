{
  "name": "@featbit/react-native-sdk",
  "version": "4.2.15",
  "description": "FeatBit client SDK for React Native",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "FeatBit",
    "React Native",
    "feature flags"
  ],
  "scripts": {
    "prebuild": "node -p \"'export const version = \\\"' + require('./package.json').version + '\\\"; export const name = \\\"' + require('./package.json').name + '\\\";'\" > src/version.ts",
    "build": "npx tsc",
    "test": "jest",
    "test:e2e": "cross-env FEATBIT_E2E=1 jest --config jest.e2e.config.js --runInBand"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/featbit/featbit-react-native-sdk.git"
  },
  "author": "FeatBit",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/featbit/featbit-react-native-sdk/issues"
  },
  "homepage": "https://github.com/featbit/featbit-react-native-sdk#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.2",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.76.0",
    "testcontainers": "^12.0.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.5",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@featbit/react-client-sdk": "4.2.15",
    "@react-native-async-storage/async-storage": "^1.23.1"
  }
}
